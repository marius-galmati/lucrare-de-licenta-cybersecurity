# =============================================================================
# CyberXscore — Production Environment
# =============================================================================
# Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# to generate JWT secrets. Replace REDACTED placeholders before deploying.

# --- Database ---
DB_PASSWORD=REDACTED_SET_STRONG_PASSWORD
DATABASE_URL=postgresql://cyberxscore:REDACTED_SET_STRONG_PASSWORD@db:5432/cyberxscore?schema=public

# --- JWT ---
JWT_SECRET=REDACTED_GENERATE_WITH_CRYPTO
ANONYMOUS_JWT_SECRET=REDACTED_GENERATE_WITH_CRYPTO

# --- Admin ---
SUPER_ADMIN_EMAILS=admin@example.com

# --- SMTP ---
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=noreply@example.com
SMTP_PASS=REDACTED_SET_MANUALLY
SMTP_SECURE=true

# --- URLs ---
FRONTEND_URL=https://your-domain.example.com
NEXT_PUBLIC_API_URL=/api
INTERNAL_API_URL=http://api:3001/api
NODE_ENV=production
