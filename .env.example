# =============================================================================
# CyberXscore Environment Variables
# =============================================================================
# Generate secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# --- Database ---
DB_PASSWORD=cyberxscore_dev
DATABASE_URL=postgresql://cyberxscore:cyberxscore_dev@localhost:5432/cyberxscore?schema=public

# --- NestJS API ---
PORT=3001
NODE_ENV=development
JWT_SECRET=change-me-in-production
ANONYMOUS_JWT_SECRET=change-me-separate-secret
SUPER_ADMIN_EMAILS=admin@example.com

# --- SMTP (password reset) ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASS=smtp-password
# SMTP_SECURE=false

# --- URLs ---
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api
INTERNAL_API_URL=http://localhost:3001/api
